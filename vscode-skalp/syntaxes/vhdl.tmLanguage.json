{
    "name": "VHDL",
    "scopeName": "source.vhdl",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#literals"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#identifiers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-dash.vhdl",
                    "match": "--.*$"
                },
                {
                    "name": "comment.block.vhdl",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.declaration.vhdl",
                    "match": "(?i)\\b(entity|architecture|package|body|configuration|component|port|generic|map)\\b"
                },
                {
                    "name": "keyword.control.vhdl",
                    "match": "(?i)\\b(process|begin|end|if|then|else|elsif|case|when|for|while|loop|generate|exit|next|return)\\b"
                },
                {
                    "name": "keyword.declaration.signal.vhdl",
                    "match": "(?i)\\b(signal|variable|constant|type|subtype|alias|attribute|file)\\b"
                },
                {
                    "name": "keyword.direction.vhdl",
                    "match": "(?i)\\b(in|out|inout|buffer)\\b"
                },
                {
                    "name": "keyword.other.vhdl",
                    "match": "(?i)\\b(is|of|with|select|others|open|null|after|transport|report|severity|assert|wait|until|on|rising_edge|falling_edge|use|library|all|function|procedure|impure|pure)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.vhdl",
                    "match": "(?i)\\b(std_logic|std_logic_vector|std_ulogic|std_ulogic_vector|unsigned|signed|integer|natural|positive|boolean|real|time|bit|bit_vector|character|string)\\b"
                }
            ]
        },
        "literals": {
            "patterns": [
                {
                    "name": "string.quoted.double.binary.vhdl",
                    "match": "\"[01XZUWLH\\-]+\""
                },
                {
                    "name": "string.quoted.double.hex.vhdl",
                    "match": "(?i)X\"[0-9a-fA-F_]+\""
                },
                {
                    "name": "constant.numeric.decimal.vhdl",
                    "match": "\\b[0-9][0-9_]*\\b"
                },
                {
                    "name": "string.quoted.single.character.vhdl",
                    "match": "'.'",
                    "comment": "Character literal"
                },
                {
                    "name": "string.quoted.double.vhdl",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.vhdl",
                            "match": "\"\""
                        }
                    ]
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.signal.vhdl",
                    "match": "<="
                },
                {
                    "name": "keyword.operator.assignment.variable.vhdl",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.association.vhdl",
                    "match": "=>"
                },
                {
                    "name": "keyword.operator.comparison.vhdl",
                    "match": "/=|=|<|>"
                },
                {
                    "name": "keyword.operator.logical.vhdl",
                    "match": "(?i)\\b(and|or|nand|nor|xor|xnor|not)\\b"
                },
                {
                    "name": "keyword.operator.shift.vhdl",
                    "match": "(?i)\\b(sll|srl|sla|sra|rol|ror)\\b"
                },
                {
                    "name": "keyword.operator.arithmetic.vhdl",
                    "match": "(?i)\\b(mod|rem|abs)\\b"
                },
                {
                    "name": "keyword.operator.concatenation.vhdl",
                    "match": "&"
                },
                {
                    "name": "keyword.operator.arithmetic.symbol.vhdl",
                    "match": "\\+|-|\\*|/|\\*\\*"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.vhdl",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
