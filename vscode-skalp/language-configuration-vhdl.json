{
    "comments": {
        "lineComment": "--",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["(", ")"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "'", "close": "'", "notIn": ["string", "comment"] }
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["\"", "\""],
        ["'", "'"],
        ["<", ">"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "(?i)^.*\\b(begin|then|loop|generate|is)\\s*$",
        "decreaseIndentPattern": "(?i)^\\s*(end\\b|begin\\b)"
    },
    "folding": {
        "markers": {
            "start": "^\\s*--\\s*#?region\\b",
            "end": "^\\s*--\\s*#?endregion\\b"
        }
    },
    "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
