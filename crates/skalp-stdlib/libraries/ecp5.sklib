[[cells.failure_modes]]
name = "stuck_at_1"
fit = 0.005
fault_type = "stuck_at_1"
mechanism = "routing_short"

[[cells.failure_modes]]
name = "open"
fit = 0.005
fault_type = "open"
mechanism = "via_failure"

