# =============================================================================
# Constant Tie Cells
# =============================================================================

[[cells]]
name = "VHI"
function = "tie_high"
fit = 0.01
inputs = []
outputs = ["Z"]
nominal_voltage_mv = 1100
min_voltage_mv = 1000
timing_margin_voltage_mv = 1050
voltage_delay_coefficient = 0.0
voltage_sensitivity = 1

[[cells.failure_modes]]
name = "stuck_at_0"
fit = 0.005
fault_type = "stuck_at_0"
mechanism = "routing_open"

[[cells.failure_modes]]
name = "open"
fit = 0.005
fault_type = "open"
mechanism = "via_failure"

[[cells]]
name = "VLO"
function = "tie_low"
fit = 0.01
inputs = []
outputs = ["Z"]
nominal_voltage_mv = 1100
