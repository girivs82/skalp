# Lattice ECP5 FPGA Library
#
# This library targets the Lattice ECP5 family (LFE5U, LFE5UM, LFE5UM5G)
# using the actual Lattice primitive names compatible with Yosys/nextpnr.
#
# References:
# - Lattice ECP5 and ECP5-5G Family Data Sheet (DS1044)
# - Lattice ECP5 sysCLOCK PLL/DLL Design and Usage Guide (TN1263)
# - Yosys ECP5 cell library
# - Project Trellis documentation

[library]
name = "ecp5"
version = "1.0.0"
vendor = "Lattice"
family = "ECP5"
reference_temperature_c = 85.0
reference_voltage_v = 1.1
lut_size = 4

# =============================================================================
# TRELLIS_LUT4 - 4-input Look-Up Table
# The fundamental logic element in ECP5. Can implement any 4-input function.
# INIT parameter contains 16-bit truth table.
# =============================================================================

[[cells]]
name = "TRELLIS_LUT4"
function = "lut4"
fit = 0.12
inputs = ["A", "B", "C", "D"]
outputs = ["Z"]
nominal_voltage_mv = 1100
min_voltage_mv = 1000
timing_margin_voltage_mv = 1045
voltage_delay_coefficient = 0.12
voltage_sensitivity = 5

[[cells.failure_modes]]
name = "config_upset"
fit = 0.06
fault_type = "data_retention"
mechanism = "sram_soft_error"

[[cells.failure_modes]]
name = "stuck_at_0"
fit = 0.012
fault_type = "stuck_at_0"
mechanism = "oxide_breakdown"

[[cells.failure_modes]]
name = "stuck_at_1"
fit = 0.012
fault_type = "stuck_at_1"
mechanism = "electromigration"

[[cells.failure_modes]]
name = "transient"
fit = 0.020
fault_type = "transient"
mechanism = "single_event_transient"

[[cells.failure_modes]]
name = "routing_open"
fit = 0.006
fault_type = "open"
mechanism = "interconnect_failure"

[[cells.failure_modes]]
name = "routing_bridge"
fit = 0.005
fault_type = "bridge"
mechanism = "interconnect_bridge"

# =============================================================================
# CCU2C - Carry Chain Cell
# Dual carry chain unit for fast arithmetic. Contains two LUT2 blocks and
# cascaded carry logic: CO = (A & B) | ((A | B) & CIN)
# =============================================================================

[[cells]]
name = "CCU2C"
function = "carry"
fit = 0.10
inputs = ["A0", "B0", "C0", "D0", "A1", "B1", "C1", "D1", "CIN"]
outputs = ["S0", "S1", "COUT"]
nominal_voltage_mv = 1100
min_voltage_mv = 1000
timing_margin_voltage_mv = 1045
voltage_delay_coefficient = 0.08
voltage_sensitivity = 4

[[cells.failure_modes]]
name = "config_upset"
fit = 0.05
fault_type = "data_retention"
mechanism = "sram_soft_error"

[[cells.failure_modes]]
name = "stuck_at_0"
fit = 0.010
fault_type = "stuck_at_0"
mechanism = "oxide_breakdown"

[[cells.failure_modes]]
name = "stuck_at_1"
fit = 0.010
fault_type = "stuck_at_1"
mechanism = "electromigration"

[[cells.failure_modes]]
name = "transient"
fit = 0.015
fault_type = "transient"
mechanism = "single_event_transient"

[[cells.failure_modes]]
name = "delay"
fit = 0.008
fault_type = "delay"
mechanism = "carry_chain_delay"

# =============================================================================
# Flip-Flops - TRELLIS_FF family
# All DFFs are positive-edge triggered.
# =============================================================================

# TRELLIS_FF - Basic D Flip-Flop
[[cells]]
name = "TRELLIS_FF"
function = "dff"
fit = 0.16
inputs = ["DI"]
outputs = ["Q"]
nominal_voltage_mv = 1100
min_voltage_mv = 1000
timing_margin_voltage_mv = 1045
voltage_delay_coefficient = 0.10
voltage_sensitivity = 3
setup_ps = 200
hold_ps = 0
clk_to_q_ps = 450

[[cells.failure_modes]]
name = "config_upset"
fit = 0.06
fault_type = "data_retention"
mechanism = "sram_soft_error"

[[cells.failure_modes]]
name = "data_retention"
fit = 0.04
fault_type = "data_retention"
mechanism = "storage_node_upset"

[[cells.failure_modes]]
name = "timing"
fit = 0.03
fault_type = "timing"
mechanism = "setup_hold_violation"

[[cells.failure_modes]]
name = "stuck_at_0"
fit = 0.012
fault_type = "stuck_at_0"
mechanism = "oxide_breakdown"

[[cells.failure_modes]]
name = "stuck_at_1"
fit = 0.012
fault_type = "stuck_at_1"
mechanism = "electromigration"

# TRELLIS_FF_E - D Flip-Flop with Enable
[[cells]]
